# Server Configuration
NODE_ENV=development
PORT=3000

# Database
DATABASE_PATH=./data/jobs.db

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Scraper Schedule (cron format)
SCRAPER_SCHEDULE=0 7 * * *
FOLLOWUP_SCHEDULE=0 9 * * *
BACKUP_SCHEDULE=59 23 * * 0

# User Profile
USER_NAME=Siddharth
USER_EMAIL=siddharthgmmmut@gmail.com
USER_PHONE=+91-8765627606

# LinkedIn Session (get from browser cookies after login)
# In Chrome: DevTools > Application > Cookies > linkedin.com > li_at
LINKEDIN_SESSION_COOKIE=

# Optional: User-Agent string (leave blank to use default)
SCRAPER_USER_AGENT=

# Backup Configuration
BACKUP_DIR=./backups
MAX_BACKUPS=12

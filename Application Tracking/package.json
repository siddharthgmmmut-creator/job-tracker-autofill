{
  "name": "job-application-tracker",
  "version": "1.0.0",
  "description": "Siddharth's Job Application Tracking & Referral System",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "setup": "node database/db.js",
    "backup": "node -e \"require('./services/backup').createBackup()\"",
    "scrape": "node -e \"require('./services/scheduler').runManualScrape()\"",
    "logs": "tail -f logs/app.log"
  },
  "keywords": [
    "job-tracker",
    "referral",
    "applications"
  ],
  "author": "Siddharth",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.7",
    "better-sqlite3": "^9.4.3",
    "cheerio": "^1.0.0-rc.12",
    "cors": "^2.8.5",
    "dotenv": "^16.4.4",
    "express": "^4.18.2",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "puppeteer": "^22.2.0",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "nodemon": "^3.0.3"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
